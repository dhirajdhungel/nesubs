# Copy this to .env and fill values (DO NOT commit real secrets)
# Frontend (Vite) env vars must be prefixed with VITE_
VITE_API_BASE_URL=http://localhost:8787
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_ANON_KEY=

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/nesubs_db

# Storage (S3-compatible)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
R2_ENDPOINT=
# Example R2 public base: https://4bc83519b659e12dc0457aa6200da304.r2.cloudflarestorage.com/nesubs

# Email provider (Resend in this project)
RESEND_API_KEY=

# Encryption/Secrets
ENCRYPTION_KEY=

# Other service secrets
# PAYMENT_GATEWAY_API_KEY=
# PAYMENT_GATEWAY_API_SECRET=
